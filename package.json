{
  "name": "necrosis-ai",
  "version": "3.0.0",
  "description": "Necrosis AI — Advanced Multi-Agent AI Assistant (Full-Stack) with OAuth Login",
  "main": "server.js",
  "author": "RajaStarboy",
  "license": "MIT",
  "homepage": "https://necrosis-chat-ai-pro.vercel.app",
  "repository": { "type": "git", "url": "https://github.com/RajaModders" },
  "scripts": {
    "start":         "node server.js",
    "dev":           "nodemon server.js",
    "dev:debug":     "NODE_ENV=development nodemon --inspect server.js",
    "test":          "node -e \"require('./ai-engine'); console.log('✅ AI Engine OK')\"",
    "build":         "vite build",
    "dev:frontend":  "vite",
    "build:preview": "vite preview"
  },
  "engines": { "node": ">=18.0.0", "npm": ">=8.0.0" },
  "dependencies": {
    "express":              "^4.18.2",
    "cors":                 "^2.8.5",
    "dotenv":               "^16.3.1",
    "node-fetch":           "^3.3.2",
    "express-rate-limit":   "^7.1.5",
    "helmet":               "^7.1.0",
    "compression":          "^1.7.4",
    "morgan":               "^1.10.0",
    "ws":                   "^8.16.0",
    "uuid":                 "^9.0.1",
    "marked":               "^9.1.6",
    "highlight.js":         "^11.9.0",
    "tiktoken":             "^1.0.10",
    "passport":             "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-facebook":    "^3.0.0",
    "passport-twitter":     "^1.0.4",
    "express-session":      "^1.18.0",
    "connect-sqlite3":      "^0.9.14",
    "better-sqlite3":       "^9.4.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "eslint":  "^8.55.0",
    "vite":    "^5.0.0",
    "terser":  "^5.26.0"
